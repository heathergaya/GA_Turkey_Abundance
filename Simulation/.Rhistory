gpp_dat <- read.csv('~/Downloads/gpp_statistical_test_df.csv')
gpp_dat <- subset(gpp_dat, gpp_dat$GPP > 0)
table(gpp_dat$PlanetMass) #18 mass options
table(gpp_dat$StellarMass) # 6 stellar masses
table(gpp_dat$Distance) #18 distance options
hist(gpp_dat$GPP) #very 0 heavy
cor(gpp_dat$StellarMass, gpp_dat$Distance)
plot(gpp_dat$StellarMass, gpp_dat$Distance)
library(statmod)
library(tweedie)
Twd1 <- glm(GPP ~ PlanetMass + I(PlanetMass^2) + Distance * StellarMass,
family = tweedie(var.power = 1.5, link.power = 0),
data = gpp_dat)
Twd2 <- glm(GPP ~ PlanetMass + Distance * StellarMass,
family = tweedie(var.power = 1.5, link.power = 0),
data = gpp_dat)
Twd3 <- glm(GPP ~ PlanetMass + I(PlanetMass^2) + Distance,
family = tweedie(var.power = 1.5, link.power = 0),
data = gpp_dat)
Twd4 <- glm(GPP ~ PlanetMass*Distance + StellarMass,
family = tweedie(var.power = 1.5, link.power = 0),
data = gpp_dat)
Twd4
summary(Twd4)
Twd4 <- glm(GPP ~ PlanetMass*Distance,
family = tweedie(var.power = 1.5, link.power = 0),
data = gpp_dat)
Twd4
sumary(Twd4)
summary(Twd4)
Twd4 <- glm(GPP ~ PlanetMass*Distance*StellarMass,
family = tweedie(var.power = 1.5, link.power = 0),
data = gpp_dat)
summary(Twd4)
Twd4 <- glm(GPP ~ PlanetMass*Distance*StellarMass,
family = tweedie(var.power = 1.5, link.power = 0),
data = gpp_dat)
1 - deviance(Twd4) / deviance(update(Twd4, . ~ 1)) #66% variation explained
par(mfrow = c(2,2))
plot(Twd4)
cv.glm(gpp_dat, Twd4, K = 10)$delta[2] #smaller the better!
??cv.glm
library(boot)
cv.glm(gpp_dat, Twd4, K = 10)$delta[2] #smaller the better!
plot(fitted(Twd2), gpp_dat$GPP)
plot(fitted(Twd4), gpp_dat$GPP)
plot(fitted(Twd4), gpp_dat$GPP)
abline(a =0, b= 1)
library(ggplot2)
ggplot(gpp_dat, aes(x = Distance, y = GPP, color = as.character(StellarMass))) +
geom_point()+
facet_wrap(~StellarMass, scales = 'free_x')+
geom_smooth(method = "glm", method.args = list(family = tweedie(var.power = 1.5)))+
theme_bw()
ggplot(gpp_dat, aes(x = PlanetMass, y = GPP, color = as.character(StellarMass))) +
geom_point()+

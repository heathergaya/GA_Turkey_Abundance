gpp.diag <- glm.diag(Twd4)
muhat <- fitted(Twd4)
(cv.err <- mean((Twd4$y - muhat)^2/(1 - gpp.diag$h)^2))
cv.glm(gpp_dat, Twd4, K = 10)$delta[2] #smaller the better!

# Column containing names
name_col <- "owner"   # <-- change this to your column name
# Function to fix each name
fix_name <- function(x) {
if (is.na(x)) return(x)
# If there's no comma, return unchanged
if (!str_detect(x, ",")) return(str_trim(x))
# Split at first comma
parts <- str_split_fixed(x, ",", 2)
last <- str_trim(parts[1])
first <- str_trim(parts[2])
# Return FIRST LAST
paste(first, last)
}
# Apply transformation
GeorgiaOver5Acres[[name_col]] <- sapply(GeorgiaOver5Acres[[name_col]], fix_name)
library(dplyr)
